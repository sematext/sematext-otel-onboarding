# Copy to .env and fill in your Sematext Tracing App token.
# .env is gitignored — never commit your real token.

# The Tracing App token from Sematext Cloud (Tracing Apps → your App → Integrations).
SEMATEXT_TRACING_TOKEN=

# Sematext managed OTLP endpoint. Defaults to EU. Change to US if needed:
#   US: https://otlp-receiver.sematext.com
#   EU: https://otlp-receiver.eu.sematext.com
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-receiver.eu.sematext.com

# Service name as it appears in the Sematext Tracing App.
OTEL_SERVICE_NAME=e2e-backend

# Backend HTTP port.
PORT=3000
