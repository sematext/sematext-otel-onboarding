{
    "name": "sematext/otel-php-laravel-auto",
    "description": "PHP Laravel OpenTelemetry Auto-Instrumentation Example",
    "type": "project",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "open-telemetry/opentelemetry-auto-laravel": "^0.0.27",
        "open-telemetry/exporter-otlp": "^1.0",
        "open-telemetry/sdk": "^1.0",
        "guzzlehttp/guzzle": "^7.0",
        "ext-opentelemetry": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
